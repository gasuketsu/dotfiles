root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true

[*.{go,mod}]
indent_style = tab

[Makefile*]
indent_style = tab

[*.{mk,am,am.*}]
indent_style = tab

[.gitconfig]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.{html,css,scss}]
indent_size = 2

[*.{xml,xmlc}]
indent_size = 2
